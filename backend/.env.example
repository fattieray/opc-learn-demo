# OPC Learn Demo Backend - Environment Configuration

# Application
APP_NAME=OPC Learn Demo
APP_VERSION=0.1.0
ENVIRONMENT=development

# Database (SQLite for lightweight demo)
DATABASE_URL=sqlite+aiosqlite:///./opc_learn_demo.db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:9000"]
